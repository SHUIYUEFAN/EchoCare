{
  "expo": {
    "name": "echo-family",
    "slug": "echo-family",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCalendarsUsageDescription": "EchoCare 需要访问日历，用于家人行程同步与提醒。",
        "NSPhotoLibraryUsageDescription": "EchoCare 需要访问相册，用于家庭照片共享与回忆记录。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-media-library",
      "expo-calendar"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
