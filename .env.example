# Copy to services/api/.env or apps as needed (never commit real secrets).

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# API
PORT=3001
EXPO_PUBLIC_API_BASE_URL=https://echocare-tc2e.onrender.com
OTP_MODE=mock
OTP_TTL_SEC=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SEC=60
OTP_DAILY_LIMIT_PER_PHONE=10
OTP_SECRET=replace-with-random-secret
SMS_PROVIDER=mock
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=EchoCare
OTP_EMAIL_TEMPLATE=Your EchoCare verification code is {{code}}. It expires in {{ttl}} minutes.
AUTH_USER_TABLE=auth_users

# LLM / Voice (Sprint 2+)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MINIMAX_API_KEY=
